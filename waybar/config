{
  "layer": "top",
  "position": "top",
  "margin-bottom": 1,
  "spacing" : 0,
  "modules-left": [
  "sway/workspaces",
  // "custom/uptime",
  "cpu"
  // "memory"
  ],

  "modules-center": ["clock"],

  "modules-right": [
    // "custom/status-squares",
    // "bluetooth",
    "network",
    "pulseaudio", 
    "backlight",
    "battery"
    // "custom/notifications",
