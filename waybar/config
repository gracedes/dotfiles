{
  "layer": "top",
  "position": "top",
  "margin-bottom": 1,
  "spacing" : 0,
  "modules-left": [
  "sway/workspaces",
  "custom/uptime",
  "cpu",
  "memory"
  ],

  "modules-center": ["clock"],

  "modules-right": [
    "custom/status-squares",
    // "bluetooth",
    "network",
    "pulseaudio", 
    "backlight",
    "battery",
    "custom/notifications",
    "custom/wlogout"
  ],

  "sway/workspaces": {
        "on-click": "activate",
        "disable-scroll": true,
        "all-outputs": true,
        "show-special": true,
        "persistent-workspaces": {
            "*": [ 1, 2, 3, 4 ],
        },
    },

  "bluetooth": {
    "format": "≤░Γ▓",
    "format-on": "{icon}",
    "format-off": "{icon}", 
    "format-connected":"{icon}",
    "format-icons":{
        "on":"≤░Γψ",
        "off": "≤░Γ▓",
        "connected": "≤░Γ▒",
        },
    "on-click": "~/.config/waybar/scripts/bluetooth_off_and_on.sh",
    "tooltip-format-connected":"{device_enumerate}"
  },

  "custom/music": {
    "format": "≤░ζγ   {}",
    "escape": true,
    "interval": 5,
    "tooltip": false,
    "exec": "playerctl metadata --format='{{ artist }} - {{ title }}'",
    "on-click": "playerctl play-pause",
    "max-length": 50
  },

  "clock": {
    "timezone": "NorthAmerica/NewYork",
    "tooltip": false,
    "format": "{:%I:%M:%S  -  %A, %d}",
    "interval": 1,
    "on-click": "firefox https://calendar.google.com/calendar/u/0/r"
  },

  "network": {
    "format-wifi": " ≤░νλ",
    "format-ethernet": " ≤░ΙΑ ",
    "format-disconnected":" ≤░νι ",
    "interval": 5,
    "tooltip-format": "{essid} ({signalStrength}%)",
    "on-click": "nm-connection-editor"

 },

  "cpu": {
    "interval": 1,
    "format": "ΎΜδ {icon0}{icon1}{icon2}{icon3}{icon4}{icon5}{icon6}{icon7} {usage:>2}%",
    "format-icons": ["έΨΒ", "έΨΓ", "έΨΔ", "έΨΕ", "έΨΖ", "έΨΗ", "έΨΘ", "έΨΙ"],
    "on-click": "kitty -e btop"
  },

  "memory": {
    "interval": 1,
    "format": "Ό┐Ζ  {used:0.1f}/{total:0.1f}G",
    "on-click": "kitty -e btop",
    "tooltip-format": "Memory"
  },

  "custom/uptime": {
    "format": "{}",
    "format-icon": ["ΎΒλ"],
    "tooltip": false,
    "interval": 5,
    "exec": "uptime -p | sed 's/up //'"
  },

  "custom/status-squares": {
    "format": "{}",
    "return-type": "json",
    "exec": "~/.config/waybar/scripts/and-on-the-seventh-day-he-commited.sh",
    "interval": 660,
    "tooltip": false,
    "on-click": "firefox https://github.com/gracedes"
  },
  
  "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["ΌΟΞ","≤░Δε", "≤░Δδ", "≤░Δη","≤░Δζ","≤░Δθ","≤░Δι"],
        "tooltip": false
  },
  
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "ΎΣο",
    "format-icons": {
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ "]
    },
    "on-click": "pavucontrol"
  },

  "battery": {
        "interval":2,
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-full": "{icon} {capacity}%",
        "format-charging": "ΎΘο {capacity}%",
        "format-plugged": "ΎΘο {capacity}%",
        "format-alt": "{icon} {time}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",C
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
  },
  
  "custom/wlogout": {
  "tooltip": false,
  "on-click": "poweroff",
  "format" : "ΎΑΣ"
  },

  "custom/notifications":{
        "format": "{icon}",
        "format-icons": {
            "notification": "ΎΓλ<span foreground='#f6aead'><sup>ΎΣΕ</sup></span>",
            "none": "ΎΓλ",
            "dnd-notification": "ΎΘ╖<span foreground='#f6aead'><sup>ΎΣΕ</sup></span>",
            "dnd-none": "ΎΘ╖",
            "inhibited-notification": "ΎΓλ<span foreground='#f6aead'><sup>ΎΣΕ</sup></span>",
            "inhibited-none": "ΎΓλ",
            "dnd-inhibited-notification": "ΎΘ╖<span foreground='#f6aead'><sup>ΎΣΕ</sup></span>",
            "dnd-inhibited-none": "ΎΘ╖"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "sleep 0.1 && swaync-client -t -sw",
        "on-click-right": "sleep 0.1 && swaync-client -d -sw",
        "escape": true
  }

}
