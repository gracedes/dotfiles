{
  "layer": "top",
  "position": "top",
  "output": "!DP-1",
  "margin-bottom": 1,
  "spacing" : 0,
  "modules-left": [
  "sway/workspaces",
  // "custom/uptime",
  "cpu",
  "memory"
  ],

  "modules-center": ["clock"],

  "modules-right": [
    "custom/status-squares",
    // "bluetooth",
    "network",
    // "custom/airpods",
    "pulseaudio", 
    "backlight",
    "battery"
    // "custom/notifications",
    // "custom/wlogout"
  ],

  "sway/workspaces": {
        "on-click": "activate",
        "disable-scroll": true,
        "all-outputs": true,
        "show-special": true,
        "persistent-workspaces": {
            "*": [ 1, 2, 3, 4 ],
        },
    },

  "bluetooth": {
    "format": "ґ░В▓",
    "format-on": "{icon}",
    "format-off": "{icon}", 
    "format-connected":"{icon}",
    "format-icons":{
        "on":"ґ░Вп",
        "off": "ґ░В▓",
        "connected": "ґ░В▒",
        },
    "on-click": "~/.config/waybar/scripts/bluetooth_off_and_on.sh",
    "tooltip-format-connected":"{device_enumerate}"
  },

  "custom/music": {
    "format": "ґ░ЭЪ   {}",
    "escape": true,
    "interval": 5,
    "tooltip": false,
    "exec": "playerctl metadata --format='{{ artist }} - {{ title }}'",
    "on-click": "playerctl play-pause",
    "max-length": 50
  },

  "clock": {
    "timezone": "NorthAmerica/NewYork",
    "tooltip": false,
    "format": "{:%I:%M:%S %A %d}",
    "interval": 1,
    "on-click": "firefox https://calendar.google.com/calendar/u/0/r"
  },

  "network": {
    "format-wifi": " ґ░дв",
    "format-ethernet": " ґ░ИА ",
    "format-disconnected":" ґ░да ",
    "interval": 5,
    "tooltip-format": "{essid} ({signalStrength}%)",
    "on-click": "nm-connection-editor"

 },

  "cpu": {
    "interval": 1,
    "format": "яЛЫ {icon0}{icon1}{icon2}{icon3}{icon4}{icon5}{icon6}{icon7} {usage:>2}%",
    "format-icons": ["тЦБ", "тЦВ", "тЦГ", "тЦД", "тЦЕ", "тЦЖ", "тЦЗ", "тЦИ"],
    "on-click": "kitty -e btop"
  },

  "memory": {
    "interval": 1,
    "format": "ю┐Е {percentage:>2}%",
    "on-click": "kitty -e btop",
    "tooltip-format": "Memory"
  },

  "custom/uptime": {
    "format": "{}",
    "format-icon": ["яБв"],
    "tooltip": false,
    "interval": 5,
    "exec": "uptime -p | sed 's/up //'"
  },

  "custom/status-squares": {
    "format": "{}",
    "return-type": "json",
    "exec": "~/.config/waybar/scripts/and-on-the-seventh-day-he-commited.sh",
    "interval": 660,
    "tooltip": false,
    "on-click": "firefox https://github.com/gracedes"
  },
  
  "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["юОН","ґ░ГЬ", "ґ░ГЫ", "ґ░ГЮ","ґ░ГЭ","ґ░ГЯ","ґ░Га"],
        "tooltip": false
  },
  
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "яСж",
    "format-icons": {
      "default": ["яАж", "яАз", "яАи "]
    },
    "on-click": "pavucontrol"
  },

  "custom/airpods": {
    "format": "юМР.{}",
    "return-type": "json",
    "exec": "~/.config/waybar/scripts/bluetooth-actions.sh --status 14:85:09:EE:D5:4C",
    "interval": 660,
    "tooltip": false,
    "on-click": "~/.config/waybar/scripts/bluetooth-actions.sh --status 14:85:09:EE:D5:4C"
  },

  "battery": {
        "interval":2,
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-full": "{icon} {capacity}%",
        "format-charging": "яЗж {capacity}%",
        "format-plugged": "яЗж {capacity}%",
        "format-alt": "{icon} {time}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",C
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
  },
  
  "custom/wlogout": {
  "tooltip": false,
  "on-click": "poweroff",
  "format" : "яАС"
  },

  "custom/notifications":{
        "format": "{icon}",
        "format-icons": {
            "notification": "яВв<span foreground='#facedc'><sup>яСД</sup></span>",
            "none": "яВв",
            "dnd-notification": "яЗ╖<span foreground='#facedc'><sup>яСД</sup></span>",
            "dnd-none": "яЗ╖",
            "inhibited-notification": "яВв<span foreground='#facedc'><sup>яСД</sup></span>",
            "inhibited-none": "яВв",
            "dnd-inhibited-notification": "яЗ╖<span foreground='#facedc'><sup>яСД</sup></span>",
            "dnd-inhibited-none": "яЗ╖"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "sleep 0.1 && swaync-client -t -sw",
        "on-click-right": "sleep 0.1 && swaync-client -d -sw",
        "escape": true
  }

}
