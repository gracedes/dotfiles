{
  "layer": "top",
  "position": "top",
  "margin-bottom": 1,
  "spacing" : 0,
  "modules-left": [
  "sway/workspaces",
  "custom/uptime",
  "cpu",
  "memory" 
  ],

  "modules-center": ["clock"],

  "modules-right": [
    // "bluetooth",
    "network",
    "pulseaudio", 
    "backlight",
    "battery",
    // "custom/notifications",
    "custom/wlogout"
  ],
  
  

  "sway/workspaces": {
        "on-click": "activate",
        "disable-scroll": true,
        "all-outputs": true,
        "show-special": true,
        "persistent-workspaces": {
            "*": [ 1, 2, 3, 4 ],
        },
    },

  "bluetooth": {
    "format": "¾░é▓",
